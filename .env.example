# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored and read only by `vercel dev` for local development.
# Production uses the values set in the Vercel dashboard
# (Project → Settings → Environment Variables) — the two are separate.

# Required: server-side Anthropic API key used by api/generate.js.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: comma-separated list of origins allowed to call the function (CORS).
# Leave unset to allow all origins during local dev.
# Example: ALLOWED_ORIGIN=https://readrise-pi.vercel.app,http://localhost:3000
ALLOWED_ORIGIN=
